# GitHub App credentials
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_PRIVATE_KEY_PATH=./private-key.pem

# Redis - if you don't have Redis locally, the server falls back to in-memory LRU
REDIS_URL=redis://localhost:6379

# Token for talking to GitHub API (only needed for forkHistory, being removed in Part 2)
# GITHUB_PAT=

PORT=3001
